# Cloudflare D1 Database
# Create at: https://dash.cloudflare.com -> Workers & Pages -> D1
# Example: wrangler d1 create mp3-musica
D1_DATABASE_ID=your_d1_database_id

# Cloudflare KV Namespaces
# Example: wrangler kv namespace create mp3-cache
KV_CACHE_ID=your_kv_cache_id
KV_SESSIONS_ID=your_kv_sessions_id

# Cloudflare R2 Bucket
# Example: wrangler r2 bucket create mp3-assets
R2_BUCKET_NAME=mp3-assets

# Cloudflare Turnstile (anti-bot)
# Get from: https://dash.cloudflare.com -> Turnstile
TURNSTILE_SITE_KEY=0x4AAAAAAC1GBYPT9A_A4N4k
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Telegram Bot (notifications)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Resend (newsletter emails)
# Get from: https://resend.com
RESEND_API_KEY=re_123456789

# Stripe (payments)
# Get from: https://stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Google Search Console
# Verification code from Google Search Console
GOOGLE_SITE_VERIFICATION=your_verification_code

# Cloudflare AI (content generation)
# Uses @cloudflare/ai in Workers
# No API key needed, uses Workers AI
